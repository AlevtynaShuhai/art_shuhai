{
  "kind": "collectionType",
  "collectionName": "artworks",
  "info": {
    "singularName": "artwork",
    "pluralName": "artworks",
    "displayName": "Artwork",
    "description": "Gallery artworks from students and instructor"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "type": {
      "type": "enumeration",
      "enum": ["student", "instructor"],
      "required": true
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
