{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Event",
    "description": "Art class events and workshops"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "date": {
      "type": "date",
      "required": true
    },
    "time": {
      "type": "string"
    },
    "startTime": {
      "type": "time"
    },
    "endTime": {
      "type": "time"
    },
    "flexibleSchedule": {
      "type": "boolean",
      "default": false
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "priceLabel": {
      "type": "string"
    },
    "location": {
      "type": "string",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "shortDescription": {
      "type": "text"
    },
    "fullDescription": {
      "type": "richtext"
    },
    "modalDescription": {
      "type": "richtext"
    },
    "includes": {
      "type": "component",
      "repeatable": true,
      "component": "event.include-item"
    },
    "discount": {
      "type": "decimal"
    },
    "eventType": {
      "type": "enumeration",
      "enum": ["one-time", "regular"],
      "default": "one-time",
      "required": true
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "capacity": {
      "type": "integer",
      "default": null
    },
    "bookedSeats": {
      "type": "integer",
      "default": 0
    }
  }
}
