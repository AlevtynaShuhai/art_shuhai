# ===========================================
# DRAWING MASTER - Environment Variables
# Copy this to .env and fill in the values
# ===========================================

# ----- Database (PostgreSQL) -----
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=your_secure_password_here

# ----- Strapi Secrets -----
# Generate with: openssl rand -base64 32
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=your_api_token_salt
ADMIN_JWT_SECRET=your_admin_jwt_secret
TRANSFER_TOKEN_SALT=your_transfer_token_salt
JWT_SECRET=your_jwt_secret

# ----- URLs -----
# For Coolify, use your domain names
NEXT_PUBLIC_STRAPI_URL=https://cms.yourdomain.com
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ----- CORS -----
# Comma-separated list of allowed origins for Strapi
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ----- Strapi API Token -----
# Create this in Strapi Admin Panel: Settings > API Tokens
STRAPI_API_TOKEN=your_strapi_api_token

# ----- Stripe -----
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ----- Telegram Bot -----
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ----- Google Sheets -----
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
GOOGLE_SHEET_ID=your_sheet_id

# ----- Analytics -----
NEXT_PUBLIC_GA_ID=G-8C33QM7EF7
NEXT_PUBLIC_FB_PIXEL_ID=551397814563158
