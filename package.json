{
  "name": "drawing-master-v2",
  "version": "1.0.0",
  "private": true,
  "description": "Art Classes with Alevtyna - Strapi CMS + Next.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:cms\" \"npm run dev:frontend\"",
    "dev:cms": "npm run develop --prefix cms",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "npm run build:cms && npm run build:frontend",
    "build:cms": "npm run build --prefix cms",
    "build:frontend": "npm run build --prefix frontend",
    "start": "concurrently \"npm run start:cms\" \"npm run start:frontend\"",
    "start:cms": "npm run start --prefix cms",
    "start:frontend": "npm run start --prefix frontend",
    "install:all": "npm install && npm install --prefix cms && npm install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "form-data": "^4.0.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
